{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/inventario-system/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/inventario-system/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/inventario-system",
  "projects": {
    "inventario-system": {
      "type": "application",
      "root": "apps/inventario-system",
      "entryFile": "main",
      "sourceRoot": "apps/inventario-system/src",
      "compilerOptions": {
        "tsConfigPath": "apps/inventario-system/tsconfig.app.json"
      }
    },
    "producto": {
      "type": "application",
      "root": "apps/producto",
      "entryFile": "main",
      "sourceRoot": "apps/producto/src",
      "compilerOptions": {
        "tsConfigPath": "apps/producto/tsconfig.app.json"
      }
    }
  }
}