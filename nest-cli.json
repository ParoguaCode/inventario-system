{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/producto/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "tsConfigPath": "apps/producto/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/producto",
  "projects": {
    "producto": {
      "type": "application",
      "root": "apps/producto",
      "entryFile": "main",
      "sourceRoot": "apps/producto/src",
      "compilerOptions": {
        "tsConfigPath": "apps/producto/tsconfig.app.json"
      }
    },
    "inventario": {
      "type": "application",
      "root": "apps/inventario",
      "entryFile": "main",
      "sourceRoot": "apps/inventario/src",
      "compilerOptions": {
        "tsConfigPath": "apps/inventario/tsconfig.app.json"
      }
    },
    "reposicion": {
      "type": "application",
      "root": "apps/reposicion",
      "entryFile": "main",
      "sourceRoot": "apps/reposicion/src",
      "compilerOptions": {
        "tsConfigPath": "apps/reposicion/tsconfig.app.json"
      }
    },
    "contracts": {
      "type": "library",
      "root": "libs/contracts",
      "entryFile": "index",
      "sourceRoot": "libs/contracts/src",
      "compilerOptions": {
        "tsConfigPath": "libs/contracts/tsconfig.lib.json"
      }
    }
  }
}